rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // REGLAS DE SEGURIDAD — Asistente HYS
    // Principio: negar todo por defecto, permitir solo lo explícitamente necesario.
    // =========================================================================

    // ── Datos de usuario ──────────────────────────────────────────────────────
    // Cada usuario solo puede leer/escribir su propia carpeta /users/{uid}/**
    match /users/{uid}/{document=**} {
      // Lectura: solo el propio usuario autenticado
      allow read: if request.auth != null && request.auth.uid == uid;

      // Escritura: solo el propio usuario, con límites de tamaño para prevenir abuso
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.keys().size() < 150
                   && request.resource.size() < 500 * 1024; // máx 500 KB por documento
    }

    // ── Subscripción (PAYWALL) ─────────────────────────────────────────────────
    // Solo el backend (Admin SDK) puede escribir subscriptionData.
    // Los clientes solo pueden leer su propio estado de suscripción.
    match /users/{uid}/data/subscriptionData {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Solo Admin SDK (Cloud Functions)
    }

    // ── Solicitudes de registro ──────────────────────────────────────────────
    // Contiene PII y datos de pago en proceso. Solo el backend puede acceder.
    match /registration_requests/{docId} {
      allow read, write: if false;
    }

    // ── Códigos de reseteo de contraseña ─────────────────────────────────────
    // Solo el Admin SDK (Cloud Functions) genera y valida estos códigos.
    // Los clientes no pueden leer ni escribir sus propios códigos.
    match /passwordResetCodes/{uid} {
      allow read, write: if false;
    }

    // ── Colecciones públicas de solo lectura ──────────────────────────────────
    // Si en el futuro necesitás datos públicos (ej. normativas), agregarlos aquí:
    // match /public/{document=**} {
    //   allow read: if true;
    //   allow write: if false;
    // }

    // ── Deny-all por defecto ──────────────────────────────────────────────────
    // Todo acceso a colecciones no definidas explícitamente queda bloqueado.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
