rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla global de aislamiento Multi-Tenant (Inquilino único)
    // El wildcard {document=**} asegura que CUALQUIER subcolección o documento anidado
    // bajo la raíz del usuario (ej: /users/UID/legajos, /users/UID/data, etc.)
    // solo sea accesible si el token JWT del solicitante coincide con el {uid}.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // registration_requests is managed via Backend API only
    // Esta colección contiene PII y pagos en proceso, debe estar sellada al público.
    match /registration_requests/{docId} {
      allow read, write: if false;
    }
    
    // Default deny for all other paths para evitar colecciones no intencionadas
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
