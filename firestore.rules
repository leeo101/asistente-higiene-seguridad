rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas de seguridad mejoradas para evitar abuso de almacenamiento
    match /users/{uid}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      
      // Permitir escritura si es el dueño y el payload no es masivo (menos de 150 campos)
      // Nota: subscriptionData se deniega en una regla más específica abajo.
      allow write: if request.auth != null 
                   && request.auth.uid == uid 
                   && request.resource.data.keys().size() < 150;
    }
    
    // PAYWALL SECURITY: Prevent users from writing to their own subscriptionData
    match /users/{uid}/data/subscriptionData {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only backend admin SDK can write this
    }
    
    // registration_requests is managed via Backend API only
    // Esta colección contiene PII y pagos en proceso, debe estar sellada al público.
    match /registration_requests/{docId} {
      allow read, write: if false;
    }
    
    // SECURITY: Password reset codes are written/read only by Admin SDK (Cloud Functions)
    // Clients must NEVER be able to read or write their own reset codes
    match /passwordResetCodes/{uid} {
      allow read, write: if false;
    }
    
    // Default deny for all other paths para evitar colecciones no intencionadas
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
